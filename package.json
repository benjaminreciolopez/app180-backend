{
  "name": "app180-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "postinstall": "node scripts/postinstall.cjs",
    "test": "npx --node-options=--experimental-vm-modules jest --forceExit",
    "test:runtime": "npx --node-options=--experimental-vm-modules jest --testPathPatterns=A-runtime --forceExit",
    "test:compliance": "npx --node-options=--experimental-vm-modules jest --testPathPatterns=B-compliance --forceExit",
    "test:critical": "npx --node-options=--experimental-vm-modules jest --testPathPatterns=\"A3|A4|A5|B1|B2\" --forceExit",
    "test:simulation": "npx --node-options=--experimental-vm-modules jest --testPathPatterns=C-simulation --verbose --forceExit",
    "migrate": "node scripts/migrate.js",
    "migrate:baseline": "node scripts/migrate.js --baseline"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.40.0",
    "@supabase/supabase-js": "^2.93.3",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "chromium-bidi": "^13.1.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^171.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "luxon": "^3.7.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-forge": "^1.3.3",
    "nodemailer": "^8.0.5",
    "pdfjs-dist": "^5.4.530",
    "pg": "^8.11.3",
    "postgres": "^3.4.7",
    "puppeteer": "^24.36.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "stripe": "^20.3.1",
    "tesseract.js": "^7.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.0.10",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
